# AgentData on-prem connector configuration. Copy to .env and fill in.
# These values stay on the customer machine — only the AGENT_TOKEN is shared
# with the backend (issued by POST /api/agent/register). The DB credentials
# below NEVER leave this machine.

# Backend base URL (the deployed AgentData API).
AGENTDATA_URL=https://mdm-production-1739.up.railway.app

# Token from `POST /api/agent/register` (shown once at registration).
AGENT_TOKEN=

# SQLAlchemy URL of the on-prem database, for reading registered SOURCES.
# USE A READ-ONLY DB USER. Leave blank if this connector only backs a staging DB.
#   postgresql+psycopg2://ro_user:pass@localhost:5432/yourdb
#   mysql+pymysql://ro_user:pass@localhost:3306/yourdb
SOURCE_DATABASE_URL=

# SQLAlchemy URL of a STAGING database, for flows that WRITE results on-prem.
# USE A WRITE/ADMIN DB USER (CREATE TABLE / INSERT / etc.) — separate from the
# read-only source above. Leave blank if this connector only reads sources.
#   postgresql+psycopg2://admin_user:pass@localhost:5432/agentdata_staging
#   sqlite:////absolute/path/to/staging.db
# Set at least one of SOURCE_DATABASE_URL / STAGING_DATABASE_URL / FILES_DIR.
STAGING_DATABASE_URL=

# A LOCAL FOLDER this connector can read/write as a flow "file store" (CSV in/out).
# Files stay on this machine; only the contents a flow reads/writes move. Leave blank to
# disable. Register it in the UI: Flows → File stores → Add → "Connector (local folder)".
#   /Users/me/agentdata_files   (macOS)   |   C:\agentdata\files   (Windows)
FILES_DIR=

# Optional tuning.
POLL_INTERVAL=1.5      # seconds between polls when idle
MAX_ROWS=5000          # hard cap on rows any single query may return
